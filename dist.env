# --- Django Core ---
# Generate a real one using: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-placeholder

# Set to True for development, False for production
DEBUG=True

# Comma-separated list of hosts: localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1