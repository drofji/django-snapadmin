# SnapAdmin Environment Variables
# Copy this file to .env and fill in your values.
# All variables have sensible defaults for local development.
# For production, change SECRET_KEY, DEBUG, ALLOWED_HOSTS, and credentials.


# ── Django core ───────────────────────────────────────────────────────────────

# A secret random string used for cryptographic signing.
# MUST be changed to a long random value in production.
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production

# Enable Django debug mode. Set to False in production.
DEBUG=True

# Comma-separated list of hostnames that can serve the app.
# Use * to allow all (dev only). Set your real domain in production.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0


# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Output structured JSON logs instead of human-readable text.
# Set to True in production/Docker for log aggregation (Datadog, Loki, etc.).
JSON_LOGS=False


# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Database name
POSTGRES_DB=snapadmin

# Database user
POSTGRES_USER=snapadmin

# Database password
POSTGRES_PASSWORD=snapadmin

# Database host. When running with Docker Compose, use the service name ("db").
# Leave empty to fall back to SQLite (local dev without Docker).
POSTGRES_HOST=db

# Database port (default PostgreSQL port)
POSTGRES_PORT=5432


# ── Redis / Celery ────────────────────────────────────────────────────────────

# Redis connection URL used as Celery broker and result backend.
# When running with Docker Compose, use the service name ("redis").
REDIS_URL=redis://redis:6379/0


# ── Elasticsearch ─────────────────────────────────────────────────────────────

# Elasticsearch cluster URL
ELASTICSEARCH_URL=http://elasticsearch:9200

# Enable/disable Elasticsearch integration.
# When False, all models fall back to DB_ONLY mode regardless of es_storage_mode.
# Set to True only when an ES cluster is available.
ELASTICSEARCH_ENABLED=False


# ── SnapAdmin-specific ────────────────────────────────────────────────────────

# Automatically run the seed_demo management command on app startup.
# Useful for quick demo setup; disable in production or staging environments.
SNAPADMIN_AUTO_SEED=False

# Feature toggles — switch each API surface off independently.
# False removes the corresponding URL routes entirely (404).
SNAPADMIN_REST_API_ENABLED=True
SNAPADMIN_SWAGGER_ENABLED=True
SNAPADMIN_GRAPHQL_ENABLED=True

# Optional extra path segment prepended to every snapadmin route (REST/Swagger/
# GraphQL). Set e.g. SNAPADMIN_URL_PREFIX=snapadmin/ when your project already owns
# the mount point (e.g. /api/). Empty = historical layout.
SNAPADMIN_URL_PREFIX=

# Admin-only user-management API (/api/users/, /api/permissions/). Opt-in.
SNAPADMIN_USER_API_ENABLED=True

# API authentication classes (comma-separated dotted paths). Empty = the demo
# default (SnapAdmin token auth + Django session). Add JWT, e.g.:
#   snapadmin.api.authentication.APITokenAuthentication,rest_framework_simplejwt.authentication.JWTAuthentication
SNAPADMIN_API_AUTHENTICATION_CLASSES=

# Elasticsearch client request timeout (seconds), merged into ELASTICSEARCH_KWARGS.
ELASTICSEARCH_TIMEOUT=5

# Smart ES query routing: route `?search=` API requests on DUAL-storage models
# to Elasticsearch (fuzzy, relevance-ranked) instead of DB icontains.
# Only takes effect when ELASTICSEARCH_ENABLED=True; per-model opt-out via
# `es_query_routing = False` on the model class.
SNAPADMIN_ES_QUERY_ROUTING=True

# Max hits fetched from Elasticsearch per routed search / ES_ONLY listing.
SNAPADMIN_ES_SEARCH_LIMIT=1000

# Expose the X-Snap-Query-Backend response header (elasticsearch|database) on
# API list responses. Set False to hide the routing detail in production.
SNAPADMIN_QUERY_BACKEND_HEADER=True

# Read-replica routing (issue #15): a DATABASES alias that auto-generated
# read-only API list/retrieve queries are pinned to via .using(). Writes always
# stay on 'default'. Empty = no routing (single-database default).
# (SNAPADMIN_MASKED_FIELDS / _SSO_PROVIDERS / _NESTED_APPS are dict settings —
#  configure them in settings.py, not here.)
SNAPADMIN_ANALYTICS_DB_ALIAS=

# Audit trail (issue #7 — DORA / ISO 27001): record every admin create/update/
# delete as an immutable SnapadminAuditLog. Retention drives the --purge pass of
# `manage.py snapadmin_audit_export`.
SNAPADMIN_AUDIT_LOG_ENABLED=True
SNAPADMIN_AUDIT_RETENTION_DAYS=365

# Large-dataset performance (issue #5): use PostgreSQL's fast reltuples estimate
# instead of COUNT(*) for unfiltered changelists larger than the threshold.
# Exact count on small/filtered views and non-PostgreSQL databases.
SNAPADMIN_ESTIMATED_COUNT=True
SNAPADMIN_ESTIMATED_COUNT_THRESHOLD=100000

# Async background export (issue #6): POST /api/exports/ offloads large CSV/JSON
# exports to a Celery worker with progress tracking, cancel and resumable chunks.
SNAPADMIN_EXPORT_ENABLED=True
SNAPADMIN_EXPORT_CHUNK_SIZE=1000
# SNAPADMIN_EXPORT_DIR defaults to <BASE_DIR>/exports; point it at a persistent
# volume in production (leave unset to use the default):
# SNAPADMIN_EXPORT_DIR=/data/snapadmin-exports

# Admin-only bulk ES reindex over HTTP (POST /api/es/reindex/, IsAdminUser).
# Off by default (the endpoint 404s while disabled). Turn REINDEX_API_ASYNC on to
# offload the reindex to the snapadmin.run_es_reindex Celery task (needs a broker).
SNAPADMIN_REINDEX_API_ENABLED=False
SNAPADMIN_REINDEX_API_ASYNC=False

# GraphQL security: require authentication + per-model view permission on every
# resolver (mirrors the REST API). Never set to False in production.
SNAPADMIN_GRAPHQL_REQUIRE_AUTH=True

# GraphiQL playground. Defaults to the DEBUG value — keep out of production.
SNAPADMIN_GRAPHIQL_ENABLED=True

# API throttling (DRF): anonymous callers vs authenticated clients.
SNAPADMIN_THROTTLE_ANON=60/min
SNAPADMIN_THROTTLE_USER=600/min

# Password for the superuser that seed_demo creates. When unset, the insecure
# admin/admin default is used — allowed only while DEBUG=True.
SNAPADMIN_SEED_ADMIN_PASSWORD=


# ── Email (SMTP) — required for error alerts / daily digest ─────────────────

# Django email backend. Defaults to the console backend while DEBUG=True
# (emails are printed to stdout) and SMTP when DEBUG=False.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# SMTP server connection
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# From address for all SnapAdmin notification emails
DEFAULT_FROM_EMAIL=snapadmin@localhost


# ── Error monitoring (optional email notifications) ─────────────────────────

# Master switch: record every unhandled exception / 5xx response as an
# ErrorEvent (browsable in the admin) via SnapErrorMonitorMiddleware.
SNAPADMIN_ERROR_MONITOR_ENABLED=True

# Spike alert: when at least THRESHOLD errors occur within WINDOW_MINUTES,
# one email is sent to ALERT_EMAILS (comma-separated). At most one alert per
# window; no emails are sent while ALERT_EMAILS is empty.
SNAPADMIN_ERROR_ALERT_ENABLED=True
SNAPADMIN_ERROR_ALERT_THRESHOLD=20
SNAPADMIN_ERROR_ALERT_WINDOW_MINUTES=15
SNAPADMIN_ERROR_ALERT_EMAILS=

# Daily digest: grouped 24h error report sent by Celery Beat at HOUR:MINUTE
# (or `manage.py send_error_digest` from cron). Falls back to ALERT_EMAILS
# when DIGEST_EMAILS is empty. MAX_GROUPS caps the number of distinct error
# groups in one email so it never explodes.
SNAPADMIN_ERROR_DIGEST_ENABLED=True
SNAPADMIN_ERROR_DIGEST_EMAILS=
SNAPADMIN_ERROR_DIGEST_MAX_GROUPS=20
SNAPADMIN_ERROR_DIGEST_HOUR=8
SNAPADMIN_ERROR_DIGEST_MINUTE=0

# ErrorEvent rows older than this many days are purged by the digest task.
SNAPADMIN_ERROR_RETENTION_DAYS=30


# ── 3-2-1 database backups (optional) ────────────────────────────────────────
# 3 copies, 2 machines, 1 offsite. Each destination has its own frequency;
# the hourly Celery Beat task (api.tasks.run_db_backups) or a cron entry
# running `manage.py db_backup` ships dumps only when a destination is due.

# Master switch for scheduled backups.
SNAPADMIN_BACKUP_ENABLED=False

# How many dumps to keep per destination (oldest pruned first).
SNAPADMIN_BACKUP_KEEP=7

# Copy 1 — LOCAL: directory on this server. Also stages every dump.
SNAPADMIN_BACKUP_LOCAL_DIR=./backups
SNAPADMIN_BACKUP_LOCAL_EVERY_HOURS=24

# Copy 2 — NETWORK: directory on another server on the same network,
# reachable as a mounted share (NFS/SMB). Empty = destination disabled.
SNAPADMIN_BACKUP_NETWORK_DIR=
SNAPADMIN_BACKUP_NETWORK_EVERY_HOURS=24

# Copy 3 — REMOTE (offsite): FTP/FTPS server somewhere else in the world.
# Empty host = destination disabled. Weekly by default (168 h).
SNAPADMIN_BACKUP_FTP_HOST=
SNAPADMIN_BACKUP_FTP_PORT=21
SNAPADMIN_BACKUP_FTP_USER=
SNAPADMIN_BACKUP_FTP_PASSWORD=
SNAPADMIN_BACKUP_FTP_DIR=/
SNAPADMIN_BACKUP_FTP_TLS=False
SNAPADMIN_BACKUP_REMOTE_EVERY_HOURS=168

# Copy 3 (alternative) — SFTP over SSH (encrypted offsite transport).
# Requires the optional paramiko dependency: pip install django-snapadmin[backup]
# Empty host = destination disabled. Leave SFTP_KEY_FILE set to use key auth
# (SFTP_PASSWORD is ignored then); otherwise password auth is used. Weekly by default.
SNAPADMIN_BACKUP_SFTP_HOST=
SNAPADMIN_BACKUP_SFTP_PORT=22
SNAPADMIN_BACKUP_SFTP_USER=
SNAPADMIN_BACKUP_SFTP_PASSWORD=
SNAPADMIN_BACKUP_SFTP_KEY_FILE=
SNAPADMIN_BACKUP_SFTP_DIR=/
SNAPADMIN_BACKUP_SFTP_EVERY_HOURS=168


# ── Traefik (optional reverse proxy) ─────────────────────────────────────────
# These variables are only used when running one of the Traefik overlay files:
#   docker compose -f docker-compose.yml -f docker-compose.traefik.local.yml up --build
#   docker compose -f docker-compose.yml -f docker-compose.traefik.prod.yml up -d

# Production domain — used by docker-compose.traefik.prod.yml
# Example: admin.mycompany.com
TRAEFIK_DOMAIN=yourdomain.com

# Email for Let's Encrypt TLS certificate registration (production only)
TRAEFIK_ACME_EMAIL=your@email.com

# Reference credentials — for your own records; not used directly by Traefik
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD=changeme

# Traefik dashboard BasicAuth in htpasswd format (used by both local and prod overlays)
# Generate from USER / PASSWORD above:
#   echo $(htpasswd -nb "${TRAEFIK_DASHBOARD_USER}" "${TRAEFIK_DASHBOARD_PASSWORD}") | sed -e 's/\$/\$\$/g'
# Default below matches admin / changeme — CHANGE in production.
TRAEFIK_DASHBOARD_CREDENTIALS=admin:$$apr1$$9O1qgAeJ$$DEirfr7.WrkwuPt2yUqY7.
