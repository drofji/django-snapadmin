# SnapAdmin Environment Variables — copy to .env
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
LOG_LEVEL=INFO
JSON_LOGS=False
POSTGRES_DB=snapadmin
POSTGRES_USER=snapadmin
POSTGRES_PASSWORD=snapadmin
POSTGRES_HOST=db
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_ENABLED=False
SNAPADMIN_AUTO_SEED=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
