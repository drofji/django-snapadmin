msgid ""
"Automatic CRUD endpoints for all models. Supports filtering, pagination, and "
"token authentication."
msgstr "Endpoint CRUD automatici per tutti i modelli. Supporta filtri, paginazione e autenticazione tramite token."

msgid "Dynamic schema generation powered by Graphene."
msgstr "Generazione dinamica dello schema basata su Graphene."

#, python-format
msgid "Built with <strong>SnapAdmin</strong> v%(version)s"
msgstr "Realizzato con <strong>SnapAdmin</strong> v%(version)s"

msgid "Language"
msgstr "Lingua"

msgid "Single sign-on providers"
msgstr "Provider di single sign-on"

msgid "Or sign in with"
msgstr "Oppure accedi con"

msgid "Enter a valid phone number (e.g. +49151234567 or 089-123456)."
msgstr "Inserisci un numero di telefono valido (es. +49151234567 o 089-123456)."

msgid "Enter a valid hex color code (e.g. #FF5733 or #F53)."
msgstr "Inserisci un codice colore esadecimale valido (es. #FF5733 o #F53)."

#, python-format
msgid "File extension '%(ext)s' is not allowed. Allowed: %(allowed)s"
msgstr "L'estensione del file '%(ext)s' non è consentita. Consentite: %(allowed)s"

#, python-format
msgid "File size is %(size)s bytes. Max allowed is %(max_size)s bytes."
msgstr "La dimensione del file è di %(size)s byte. Il massimo consentito è di %(max_size)s byte."

msgid "Could not verify file encoding."
msgstr "Impossibile verificare la codifica del file."

#, python-format
msgid "Invalid encoding. Allowed: %(encodings)s"
msgstr "Codifica non valida. Consentite: %(encodings)s"

