msgid "Access Control"
msgstr "Controllo degli accessi"

msgid "Audit"
msgstr "Audit"

#, python-format
msgid "API token created. Copy it now — it will not be shown again: %(key)s"
msgstr "Token API creato. Copialo ora — non verrà mostrato di nuovo: %(key)s"

msgid "Token Key"
msgstr "Chiave del token"

msgid "hidden — shown only once at creation"
msgstr "nascosto — mostrato solo una volta alla creazione"

msgid "Status"
msgstr "Stato"

msgid "Disabled"
msgstr "Disattivato"

msgid "Expired"
msgstr "Scaduto"

msgid "Active"
msgstr "Attivo"

msgid "Message"
msgstr "Messaggio"

msgid "Changes"
msgstr "Modifiche"

msgid "Action"
msgstr "Azione"

msgid "Allowed models must be a list."
msgstr "I modelli consentiti devono essere un elenco."

#, python-format
msgid "Invalid model format: '%(item)s'."
msgstr "Formato del modello non valido: '%(item)s'."

#, python-format
msgid "Model '%(item)s' does not exist."
msgstr "Il modello '%(item)s' non esiste."

msgid "Token Name"
msgstr "Nome del token"

msgid ""
"A descriptive name for this token (e.g. 'CI Pipeline', 'Read-only "
"dashboard')."
msgstr "Un nome descrittivo per questo token (es. 'CI Pipeline', 'Dashboard di sola lettura')."

msgid "Token Prefix"
msgstr "Prefisso del token"

msgid "First 8 characters of the key, for identification. Not secret."
msgstr "I primi 8 caratteri della chiave, per l'identificazione. Non è segreto."

msgid "Token Digest"
msgstr "Digest del token"

msgid ""
"SHA-256 hash of the secret key. The raw key is never stored — it is shown "
"only once, at creation."
msgstr "Hash SHA-256 della chiave segreta. La chiave grezza non viene mai memorizzata — viene mostrata solo una volta, alla creazione."

msgid "Owner"
msgstr "Proprietario"

msgid "Expiration Date"
msgstr "Data di scadenza"

msgid "Leave blank for a token that never expires."
msgstr "Lasciare vuoto per un token che non scade mai."

#, fuzzy
#| msgid "Managed Models"
msgid "Allowed Models"
msgstr "Modelli gestiti"

msgid "List of 'app_label.ModelName' strings this token can access."
msgstr "Elenco di stringhe 'app_label.ModelName' a cui questo token può accedere."

msgid "Is Active"
msgstr "È attivo"

msgid "Inactive tokens are rejected without being deleted."
msgstr "I token inattivi vengono rifiutati senza essere eliminati."

msgid "Created At"
msgstr "Creato il"

msgid "Last Used At"
msgstr "Ultimo utilizzo il"

msgid "API Token"
msgstr "Token API"

msgid "API Tokens"
msgstr "Token API"

msgid "Can view unmasked PII data"
msgstr "Può visualizzare i dati PII non mascherati"

