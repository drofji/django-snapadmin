msgid "Rows written so far — drives progress-percent and ETA reporting."
msgstr "Righe scritte finora — determina la percentuale di avanzamento e la stima del tempo rimanente."

msgid "Resume Cursor (PK)"
msgstr "Cursore di ripresa (PK)"

msgid ""
"Primary key of the last exported row; blank means start from the beginning."
msgstr "Chiave primaria dell'ultima riga esportata; vuoto significa iniziare dall'inizio."

msgid "Resume Byte Offset"
msgstr "Offset di byte di ripresa"

msgid "Byte length of the working file confirmed at cursor_pk."
msgstr "Lunghezza in byte del file di lavoro confermata a cursor_pk."

