msgid "Method"
msgstr "Metodo"

msgid "Status Code"
msgstr "Codice di stato"

msgid "Fingerprint"
msgstr "Impronta"

msgid "SHA-256 of exception class + path — groups repeats of the same error."
msgstr "SHA-256 della classe di eccezione + percorso — raggruppa le ripetizioni dello stesso errore."

msgid "Traceback"
msgstr "Traceback"

