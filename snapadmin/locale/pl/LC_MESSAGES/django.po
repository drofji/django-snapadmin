msgid ""
"Automatic CRUD endpoints for all models. Supports filtering, pagination, and "
"token authentication."
msgstr "Automatyczne punkty końcowe CRUD dla wszystkich modeli. Obsługuje filtrowanie, paginację i uwierzytelnianie tokenem."

msgid "Dynamic schema generation powered by Graphene."
msgstr "Dynamiczne generowanie schematu oparte na Graphene."

#, python-format
msgid "Built with <strong>SnapAdmin</strong> v%(version)s"
msgstr "Zbudowano przy użyciu <strong>SnapAdmin</strong> v%(version)s"

msgid "Language"
msgstr "Język"

msgid "Single sign-on providers"
msgstr "Dostawcy logowania jednokrotnego"

msgid "Or sign in with"
msgstr "Lub zaloguj się przez"

msgid "Enter a valid phone number (e.g. +49151234567 or 089-123456)."
msgstr "Wprowadź prawidłowy numer telefonu (np. +49151234567 lub 089-123456)."

msgid "Enter a valid hex color code (e.g. #FF5733 or #F53)."
msgstr "Wprowadź prawidłowy kod koloru hex (np. #FF5733 lub #F53)."

#, python-format
msgid "File extension '%(ext)s' is not allowed. Allowed: %(allowed)s"
msgstr "Rozszerzenie pliku '%(ext)s' jest niedozwolone. Dozwolone: %(allowed)s"

#, python-format
msgid "File size is %(size)s bytes. Max allowed is %(max_size)s bytes."
msgstr "Rozmiar pliku to %(size)s bajtów. Maksymalny dozwolony to %(max_size)s bajtów."

msgid "Could not verify file encoding."
msgstr "Nie można zweryfikować kodowania pliku."

#, python-format
msgid "Invalid encoding. Allowed: %(encodings)s"
msgstr "Nieprawidłowe kodowanie. Dozwolone: %(encodings)s"

