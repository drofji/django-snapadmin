msgid "Access Control"
msgstr "Kontrola dostępu"

msgid "Audit"
msgstr "Audyt"

#, python-format
msgid "API token created. Copy it now — it will not be shown again: %(key)s"
msgstr "Token API utworzony. Skopiuj go teraz — nie zostanie pokazany ponownie: %(key)s"

msgid "Token Key"
msgstr "Klucz tokena"

msgid "hidden — shown only once at creation"
msgstr "ukryty — pokazywany tylko raz przy tworzeniu"

msgid "Status"
msgstr "Status"

msgid "Disabled"
msgstr "Wyłączony"

msgid "Expired"
msgstr "Wygasły"

msgid "Active"
msgstr "Aktywny"

msgid "Message"
msgstr "Wiadomość"

msgid "Changes"
msgstr "Zmiany"

msgid "Action"
msgstr "Akcja"

msgid "Allowed models must be a list."
msgstr "Dozwolone modele muszą być listą."

#, python-format
msgid "Invalid model format: '%(item)s'."
msgstr "Nieprawidłowy format modelu: '%(item)s'."

#, python-format
msgid "Model '%(item)s' does not exist."
msgstr "Model '%(item)s' nie istnieje."

msgid "Token Name"
msgstr "Nazwa tokena"

msgid ""
"A descriptive name for this token (e.g. 'CI Pipeline', 'Read-only "
"dashboard')."
msgstr "Opisowa nazwa tego tokena (np. 'CI Pipeline', 'Pulpit tylko do odczytu')."

msgid "Token Prefix"
msgstr "Prefiks tokena"

msgid "First 8 characters of the key, for identification. Not secret."
msgstr "Pierwsze 8 znaków klucza, do identyfikacji. Nie jest tajne."

msgid "Token Digest"
msgstr "Skrót tokena"

msgid ""
"SHA-256 hash of the secret key. The raw key is never stored — it is shown "
"only once, at creation."
msgstr "Skrót SHA-256 tajnego klucza. Surowy klucz nigdy nie jest przechowywany — jest pokazywany tylko raz, przy tworzeniu."

msgid "Owner"
msgstr "Właściciel"

msgid "Expiration Date"
msgstr "Data wygaśnięcia"

msgid "Leave blank for a token that never expires."
msgstr "Pozostaw puste, aby token nigdy nie wygasał."

#, fuzzy
#| msgid "Managed Models"
msgid "Allowed Models"
msgstr "Zarządzane modele"

msgid "List of 'app_label.ModelName' strings this token can access."
msgstr "Lista ciągów 'app_label.ModelName', do których ten token ma dostęp."

msgid "Is Active"
msgstr "Jest aktywny"

msgid "Inactive tokens are rejected without being deleted."
msgstr "Nieaktywne tokeny są odrzucane bez usuwania."

msgid "Created At"
msgstr "Utworzono"

msgid "Last Used At"
msgstr "Ostatnio użyto"

msgid "API Token"
msgstr "Token API"

msgid "API Tokens"
msgstr "Tokeny API"

msgid "Can view unmasked PII data"
msgstr "Może wyświetlać niezamaskowane dane PII"

