msgid "Access Control"
msgstr "Zugriffskontrolle"

msgid "Audit"
msgstr "Audit"

#, python-format
msgid "API token created. Copy it now — it will not be shown again: %(key)s"
msgstr "API-Token erstellt. Kopieren Sie es jetzt — es wird nicht erneut angezeigt: %(key)s"

msgid "Token Key"
msgstr "Token-Schlüssel"

msgid "hidden — shown only once at creation"
msgstr "verborgen — nur einmal bei der Erstellung angezeigt"

msgid "Status"
msgstr "Status"

msgid "Disabled"
msgstr "Deaktiviert"

msgid "Expired"
msgstr "Abgelaufen"

msgid "Active"
msgstr "Aktiv"

msgid "Message"
msgstr "Nachricht"

msgid "Changes"
msgstr "Änderungen"

msgid "Action"
msgstr "Aktion"

msgid "Allowed models must be a list."
msgstr "Erlaubte Modelle müssen eine Liste sein."

#, python-format
msgid "Invalid model format: '%(item)s'."
msgstr "Ungültiges Modellformat: '%(item)s'."

#, python-format
msgid "Model '%(item)s' does not exist."
msgstr "Modell '%(item)s' existiert nicht."

msgid "Token Name"
msgstr "Token-Name"

msgid ""
"A descriptive name for this token (e.g. 'CI Pipeline', 'Read-only "
"dashboard')."
msgstr "Ein beschreibender Name für dieses Token (z. B. 'CI-Pipeline', 'Nur-Lese-Dashboard')."

msgid "Token Prefix"
msgstr "Token-Präfix"

msgid "First 8 characters of the key, for identification. Not secret."
msgstr "Die ersten 8 Zeichen des Schlüssels zur Identifikation. Nicht geheim."

msgid "Token Digest"
msgstr "Token-Digest"

msgid ""
"SHA-256 hash of the secret key. The raw key is never stored — it is shown "
"only once, at creation."
msgstr "SHA-256-Hash des geheimen Schlüssels. Der Rohschlüssel wird nie gespeichert — er wird nur einmal bei der Erstellung angezeigt."

msgid "Owner"
msgstr "Besitzer"

msgid "Expiration Date"
msgstr "Ablaufdatum"

msgid "Leave blank for a token that never expires."
msgstr "Leer lassen für ein Token, das nie abläuft."

#, fuzzy
#| msgid "Managed Models"
msgid "Allowed Models"
msgstr "Verwaltete Modelle"

msgid "List of 'app_label.ModelName' strings this token can access."
msgstr "Liste von 'app_label.ModelName'-Zeichenketten, auf die dieses Token zugreifen kann."

msgid "Is Active"
msgstr "Ist aktiv"

msgid "Inactive tokens are rejected without being deleted."
msgstr "Inaktive Token werden abgelehnt, ohne gelöscht zu werden."

msgid "Created At"
msgstr "Erstellt am"

msgid "Last Used At"
msgstr "Zuletzt verwendet am"

