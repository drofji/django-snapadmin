msgstr "Dateierweiterung '%(ext)s' ist nicht erlaubt. Erlaubt: %(allowed)s"

#, python-format
msgid "File size is %(size)s bytes. Max allowed is %(max_size)s bytes."
msgstr "Die Dateigröße beträgt %(size)s Bytes. Maximal erlaubt sind %(max_size)s Bytes."

msgid "Could not verify file encoding."
msgstr "Die Dateikodierung konnte nicht überprüft werden."

#, python-format
msgid "Invalid encoding. Allowed: %(encodings)s"
msgstr "Ungültige Kodierung. Erlaubt: %(encodings)s"

