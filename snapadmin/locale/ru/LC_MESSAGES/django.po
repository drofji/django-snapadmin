msgstr "Создано"

msgid "Updated"
msgstr "Обновлено"

msgid "Deleted"
msgstr "Удалено"

msgid "Actor"
msgstr "Субъект"

msgid "Actor (snapshot)"
msgstr "Субъект (снимок)"

msgid "IP Address"
msgstr "IP-адрес"

msgid "User Agent"
msgstr "User-Agent"

msgid "Content Type"
msgstr "Тип содержимого"

msgid "App Label"
msgstr "Метка приложения"

