msgid "Access Control"
msgstr "Контроль доступа"

msgid "Audit"
msgstr "Аудит"

#, python-format
msgid "API token created. Copy it now — it will not be shown again: %(key)s"
msgstr "Токен API создан. Скопируйте его сейчас — он больше не будет показан: %(key)s"

msgid "Token Key"
msgstr "Ключ токена"

msgid "hidden — shown only once at creation"
msgstr "скрыто — показывается только один раз при создании"

msgid "Status"
msgstr "Статус"

msgid "Disabled"
msgstr "Отключён"

msgid "Expired"
msgstr "Истёк"

msgid "Active"
msgstr "Активен"

msgid "Message"
msgstr "Сообщение"

msgid "Changes"
msgstr "Изменения"

msgid "Action"
msgstr "Действие"

msgid "Allowed models must be a list."
msgstr "Разрешённые модели должны быть списком."

#, python-format
msgid "Invalid model format: '%(item)s'."
msgstr "Неверный формат модели: '%(item)s'."

#, python-format
msgid "Model '%(item)s' does not exist."
msgstr "Модель '%(item)s' не существует."

msgid "Token Name"
msgstr "Имя токена"

msgid ""
"A descriptive name for this token (e.g. 'CI Pipeline', 'Read-only "
"dashboard')."
msgstr "Описательное имя для этого токена (напр. 'CI Pipeline', 'Панель только для чтения')."

msgid "Token Prefix"
msgstr "Префикс токена"

msgid "First 8 characters of the key, for identification. Not secret."
msgstr "Первые 8 символов ключа для идентификации. Не является секретом."

msgid "Token Digest"
msgstr "Дайджест токена"

msgid ""
"SHA-256 hash of the secret key. The raw key is never stored — it is shown "
"only once, at creation."
msgstr "SHA-256-хеш секретного ключа. Исходный ключ никогда не хранится — он показывается только один раз, при создании."

msgid "Owner"
msgstr "Владелец"

msgid "Expiration Date"
msgstr "Дата истечения срока"

msgid "Leave blank for a token that never expires."
msgstr "Оставьте пустым, чтобы токен никогда не истекал."

#, fuzzy
#| msgid "Managed Models"
msgid "Allowed Models"
msgstr "Управляемые модели"

msgid "List of 'app_label.ModelName' strings this token can access."
msgstr "Список строк 'app_label.ModelName', к которым этот токен имеет доступ."

msgid "Is Active"
msgstr "Активен"

msgid "Inactive tokens are rejected without being deleted."
msgstr "Неактивные токены отклоняются без удаления."

msgid "Created At"
msgstr "Создано"

msgid "Last Used At"
msgstr "Последнее использование"

msgid "API Token"
msgstr "Токен API"

msgid "API Tokens"
msgstr "Токены API"

msgid "Can view unmasked PII data"
msgstr "Может просматривать немаскированные PII-данные"

#, fuzzy
#| msgid "Description"
msgid "Exception"
msgstr "Описание"

msgid ""
"Exception class name, or HTTP<code> for a 5xx response without an exception."
msgstr "Имя класса исключения или HTTP<code> для ответа 5xx без исключения."

msgid "Path"
msgstr "Путь"

msgid "Method"
msgstr "Метод"

msgid "Status Code"
msgstr "Код статуса"

msgid "Fingerprint"
msgstr "Отпечаток"

msgid "SHA-256 of exception class + path — groups repeats of the same error."
msgstr "SHA-256 от класса исключения + пути — группирует повторы одной и той же ошибки."

msgid "Traceback"
msgstr "Трассировка"

msgid "Occurred At"
msgstr "Произошло"

msgid "Error Event"
msgstr "Событие ошибки"

msgid "Error Events"
msgstr "События ошибок"

