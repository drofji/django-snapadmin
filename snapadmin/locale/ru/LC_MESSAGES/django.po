msgstr "Отменено"

msgid "Format"
msgstr "Формат"

msgid "Filters"
msgstr "Фильтры"

msgid "ORM field=value filters applied to the export queryset."
msgstr "ORM-фильтры поле=значение, применяемые к queryset экспорта."

msgid "Total Rows"
msgstr "Всего строк"

msgid "Processed Rows"
msgstr "Обработано строк"

msgid "Rows written so far — drives progress-percent and ETA reporting."
msgstr "Записано строк на данный момент — определяет процент выполнения и оценку времени."

msgid "Resume Cursor (PK)"
msgstr "Курсор возобновления (PK)"

msgid ""
"Primary key of the last exported row; blank means start from the beginning."
msgstr "Первичный ключ последней экспортированной строки; пусто — начать с начала."

msgid "Resume Byte Offset"
msgstr "Смещение байтов возобновления"

msgid "Byte length of the working file confirmed at cursor_pk."
msgstr "Длина рабочего файла в байтах, подтверждённая на cursor_pk."

