msgstr "Возможности API"

msgid ""
"Automatic CRUD endpoints for all models. Supports filtering, pagination, and "
"token authentication."
msgstr "Автоматические CRUD-эндпоинты для всех моделей. Поддерживают фильтрацию, пагинацию и аутентификацию по токену."

msgid "Dynamic schema generation powered by Graphene."
msgstr "Динамическая генерация схемы на основе Graphene."

#, python-format
msgid "Built with <strong>SnapAdmin</strong> v%(version)s"
msgstr "Создано с помощью <strong>SnapAdmin</strong> v%(version)s"

msgid "Language"
msgstr "Язык"

msgid "Single sign-on providers"
msgstr "Провайдеры единого входа (SSO)"

msgid "Or sign in with"
msgstr "Или войдите через"

msgid "Enter a valid phone number (e.g. +49151234567 or 089-123456)."
msgstr "Введите корректный номер телефона (напр. +49151234567 или 089-123456)."

msgid "Enter a valid hex color code (e.g. #FF5733 or #F53)."
msgstr "Введите корректный шестнадцатеричный код цвета (напр. #FF5733 или #F53)."

#, python-format
msgid "File extension '%(ext)s' is not allowed. Allowed: %(allowed)s"
msgstr "Расширение файла '%(ext)s' не разрешено. Разрешены: %(allowed)s"

#, python-format
msgid "File size is %(size)s bytes. Max allowed is %(max_size)s bytes."
msgstr "Размер файла — %(size)s байт. Максимально допустимо — %(max_size)s байт."

msgid "Could not verify file encoding."
msgstr "Не удалось проверить кодировку файла."

#, python-format
msgid "Invalid encoding. Allowed: %(encodings)s"
msgstr "Неверная кодировка. Разрешены: %(encodings)s"

