msgid "Access Control"
msgstr "Control de acceso"

msgid "Audit"
msgstr "Auditoría"

#, python-format
msgid "API token created. Copy it now — it will not be shown again: %(key)s"
msgstr "Token de API creado. Cópielo ahora, no se volverá a mostrar: %(key)s"

msgid "Token Key"
msgstr "Clave del token"

msgid "hidden — shown only once at creation"
msgstr "oculto: se muestra solo una vez al crearlo"

msgid "Status"
msgstr "Estado"

msgid "Disabled"
msgstr "Deshabilitado"

msgid "Expired"
msgstr "Caducado"

msgid "Active"
msgstr "Activo"

msgid "Message"
msgstr "Mensaje"

msgid "Changes"
msgstr "Cambios"

msgid "Action"
msgstr "Acción"

msgid "Allowed models must be a list."
msgstr "Los modelos permitidos deben ser una lista."

#, python-format
msgid "Invalid model format: '%(item)s'."
msgstr "Formato de modelo no válido: '%(item)s'."

#, python-format
msgid "Model '%(item)s' does not exist."
msgstr "El modelo '%(item)s' no existe."

msgid "Token Name"
msgstr "Nombre del token"

msgid ""
"A descriptive name for this token (e.g. 'CI Pipeline', 'Read-only "
"dashboard')."
msgstr ""
"Un nombre descriptivo para este token (p. ej. 'CI Pipeline', 'Panel de solo "
"lectura')."

msgid "Token Prefix"
msgstr "Prefijo del token"

msgid "First 8 characters of the key, for identification. Not secret."
msgstr ""
"Los primeros 8 caracteres de la clave, para identificación. No es secreto."

msgid "Token Digest"
msgstr "Resumen del token"

msgid ""
"SHA-256 hash of the secret key. The raw key is never stored — it is shown "
"only once, at creation."
msgstr ""
"Hash SHA-256 de la clave secreta. La clave sin procesar nunca se almacena: "
"se muestra solo una vez, al crearla."

msgid "Owner"
msgstr "Propietario"

msgid "Expiration Date"
msgstr "Fecha de caducidad"

msgid "Leave blank for a token that never expires."
msgstr "Déjelo en blanco para un token que nunca caduca."

msgid "Allowed Models"
msgstr "Modelos permitidos"

msgid "List of 'app_label.ModelName' strings this token can access."
msgstr ""
"Lista de cadenas 'app_label.ModelName' a las que este token puede acceder."

msgid "Is Active"
msgstr "Está activo"

msgid "Inactive tokens are rejected without being deleted."
msgstr "Los tokens inactivos se rechazan sin eliminarse."

msgid "Created At"
msgstr "Creado el"

msgid "Last Used At"
msgstr "Último uso el"

msgid "API Token"
msgstr "Token de API"

msgid "API Tokens"
msgstr "Tokens de API"

msgid "Can view unmasked PII data"
msgstr "Puede ver datos PII sin enmascarar"

msgid "Exception"
msgstr "Excepción"

msgid ""
"Exception class name, or HTTP<code> for a 5xx response without an exception."
msgstr ""
"Nombre de la clase de excepción, o HTTP<code> para una respuesta 5xx sin "
"excepción."

msgid "Path"
msgstr "Ruta"

msgid "Method"
msgstr "Método"

msgid "Status Code"
msgstr "Código de estado"

msgid "Fingerprint"
msgstr "Huella digital"

msgid "SHA-256 of exception class + path — groups repeats of the same error."
msgstr ""
"SHA-256 de la clase de excepción + ruta: agrupa repeticiones del mismo error."

msgid "Traceback"
msgstr "Traza"

msgid "Occurred At"
msgstr "Ocurrió el"

msgid "Error Event"
msgstr "Evento de error"

msgid "Error Events"
msgstr "Eventos de error"

msgid "Created"
msgstr "Creado"

msgid "Updated"
msgstr "Actualizado"

msgid "Deleted"
msgstr "Eliminado"

msgid "Actor"
msgstr "Actor"

msgid "Actor (snapshot)"
msgstr "Actor (instantánea)"

msgid "IP Address"
msgstr "Dirección IP"

msgid "User Agent"
msgstr "Agente de usuario"

msgid "Content Type"
msgstr "Tipo de contenido"

msgid "App Label"
msgstr "Etiqueta de la aplicación"

msgid "Model"
msgstr "Modelo"

msgid "Object ID"
msgstr "ID del objeto"

msgid "Object"
msgstr "Objeto"

msgid "Before/after field diff, if any."
msgstr "Diferencia de campos antes/después, si la hay."

msgid "Timestamp"
msgstr "Marca de tiempo"

msgid "Audit Log"
msgstr "Registro de auditoría"

msgid "Audit Logs"
msgstr "Registros de auditoría"

msgid "Audit log entries are immutable and cannot be modified."
msgstr ""
"Las entradas del registro de auditoría son inmutables y no se pueden "
"modificar."

msgid "Audit log entries are immutable and cannot be deleted."
msgstr ""
"Las entradas del registro de auditoría son inmutables y no se pueden "
"eliminar."

msgid "Pending"
msgstr "Pendiente"

msgid "Processing"
msgstr "Procesando"

msgid "Completed"
msgstr "Completado"

msgid "Failed"
msgstr "Fallido"

msgid "Cancelled"
msgstr "Cancelado"

msgid "Format"
msgstr "Formato"

msgid "Filters"
msgstr "Filtros"

msgid "ORM field=value filters applied to the export queryset."
msgstr "Filtros ORM campo=valor aplicados al queryset de exportación."

msgid "Total Rows"
msgstr "Filas totales"

msgid "Processed Rows"
msgstr "Filas procesadas"

msgid "Rows written so far — drives progress-percent and ETA reporting."
msgstr ""
"Filas escritas hasta ahora: determina el porcentaje de progreso y la "
"estimación de tiempo."

msgid "Resume Cursor (PK)"
msgstr "Cursor de reanudación (PK)"

msgid ""
"Primary key of the last exported row; blank means start from the beginning."
msgstr ""
"Clave primaria de la última fila exportada; en blanco significa empezar "
"desde el principio."

msgid "Resume Byte Offset"
msgstr "Desplazamiento de bytes de reanudación"

msgid "Byte length of the working file confirmed at cursor_pk."
msgstr "Longitud en bytes del archivo de trabajo confirmada en cursor_pk."

msgid "File Name"
msgstr "Nombre del archivo"

msgid "Error"
msgstr "Error"

msgid "Requested By"
msgstr "Solicitado por"

msgid "Started At"
msgstr "Iniciado el"

msgid "Finished At"
msgstr "Finalizado el"

msgid "Export Job"
msgstr "Trabajo de exportación"

msgid "Export Jobs"
msgstr "Trabajos de exportación"

msgid ""
"Primary key of the last indexed row; blank means start from the beginning."
msgstr "Clave primaria de la última fila indexada; en blanco significa empezar desde el principio."

msgid "Reindex Job"
msgstr "Trabajo de reindexación"

msgid "Reindex Jobs"
msgstr "Trabajos de reindexación"

msgid "Skip to main content"
msgstr "Saltar al contenido principal"

msgid "SnapAdmin on GitHub (opens in a new tab)"
msgstr "SnapAdmin en GitHub (se abre en una pestaña nueva)"

msgid "System entry points"
msgstr "Puntos de entrada del sistema"

msgid "System Entry Points"
msgstr "Puntos de entrada del sistema"

msgid "Managed Models"
msgstr "Modelos gestionados"

msgid "Scheduled Cron Jobs"
msgstr "Tareas programadas"

msgid "Name"
msgstr "Nombre"

msgid "Task"
msgstr "Tarea"

msgid "Schedule"
msgstr "Programación"

msgid "Description"
msgstr "Descripción"

msgid "Data Distribution"
msgstr "Distribución de datos"

msgid "Bar chart of record counts per managed model"
msgstr "Gráfico de barras del número de registros por modelo gestionado"

msgid "System Health"
msgstr "Estado del sistema"

msgid "Environment"
msgstr "Entorno"

msgid "Mode"
msgstr "Modo"

msgid "Hostname"
msgstr "Nombre de host"

msgid "API Capabilities"
msgstr "Capacidades de la API"

msgid ""
"Automatic CRUD endpoints for all models. Supports filtering, pagination, and "
"token authentication."
msgstr ""
"Endpoints CRUD automáticos para todos los modelos. Admite filtrado, "
"paginación y autenticación por token."

msgid "Dynamic schema generation powered by Graphene."
msgstr "Generación dinámica de esquemas con Graphene."

#, python-format
msgid "Built with <strong>SnapAdmin</strong> v%(version)s"
msgstr "Creado con <strong>SnapAdmin</strong> v%(version)s"

msgid "Language"
msgstr "Idioma"

msgid "Single sign-on providers"
msgstr "Proveedores de inicio de sesión único"

msgid "Or sign in with"
msgstr "O inicie sesión con"

msgid "Enter a valid phone number (e.g. +49151234567 or 089-123456)."
msgstr ""
"Introduzca un número de teléfono válido (p. ej. +49151234567 o 089-123456)."

msgid "Enter a valid hex color code (e.g. #FF5733 or #F53)."
msgstr ""
"Introduzca un código de color hexadecimal válido (p. ej. #FF5733 o #F53)."

#, python-format
msgid "File extension '%(ext)s' is not allowed. Allowed: %(allowed)s"
msgstr ""
"La extensión de archivo '%(ext)s' no está permitida. Permitidas: %(allowed)s"

#, python-format
msgid "File size is %(size)s bytes. Max allowed is %(max_size)s bytes."
msgstr ""
"El tamaño del archivo es de %(size)s bytes. El máximo permitido es de "
"%(max_size)s bytes."

msgid "Could not verify file encoding."
msgstr "No se pudo verificar la codificación del archivo."

#, python-format
msgid "Invalid encoding. Allowed: %(encodings)s"
msgstr "Codificación no válida. Permitidas: %(encodings)s"

