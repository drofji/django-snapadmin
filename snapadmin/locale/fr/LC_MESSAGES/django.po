msgid "Access Control"
msgstr "Contrôle d'accès"

msgid "Audit"
msgstr "Audit"

#, python-format
msgid "API token created. Copy it now — it will not be shown again: %(key)s"
msgstr ""
"Jeton d'API créé. Copiez-le maintenant — il ne sera plus affiché : %(key)s"

msgid "Token Key"
msgstr "Clé du jeton"

msgid "hidden — shown only once at creation"
msgstr "masqué — affiché une seule fois à la création"

msgid "Status"
msgstr "Statut"

msgid "Disabled"
msgstr "Désactivé"

msgid "Expired"
msgstr "Expiré"

msgid "Active"
msgstr "Actif"

msgid "Message"
msgstr "Message"

msgid "Changes"
msgstr "Modifications"

msgid "Action"
msgstr "Action"

msgid "Allowed models must be a list."
msgstr "Les modèles autorisés doivent être une liste."

#, python-format
msgid "Invalid model format: '%(item)s'."
msgstr "Format de modèle invalide : '%(item)s'."

#, python-format
msgid "Model '%(item)s' does not exist."
msgstr "Le modèle '%(item)s' n'existe pas."

msgid "Token Name"
msgstr "Nom du jeton"

msgid ""
"A descriptive name for this token (e.g. 'CI Pipeline', 'Read-only "
"dashboard')."
msgstr ""
"Un nom descriptif pour ce jeton (par ex. 'Pipeline CI', 'Tableau de bord en "
"lecture seule')."

msgid "Token Prefix"
msgstr "Préfixe du jeton"

msgid "First 8 characters of the key, for identification. Not secret."
msgstr ""
"Les 8 premiers caractères de la clé, à des fins d'identification. Non secret."

msgid "Token Digest"
msgstr "Empreinte du jeton"

msgid ""
"SHA-256 hash of the secret key. The raw key is never stored — it is shown "
"only once, at creation."
msgstr ""
"Empreinte SHA-256 de la clé secrète. La clé brute n'est jamais stockée — "
"elle n'est affichée qu'une seule fois, à la création."

msgid "Owner"
msgstr "Propriétaire"

msgid "Expiration Date"
msgstr "Date d'expiration"

msgid "Leave blank for a token that never expires."
msgstr "Laisser vide pour un jeton qui n'expire jamais."

msgid "Allowed Models"
msgstr "Modèles autorisés"

msgid "List of 'app_label.ModelName' strings this token can access."
msgstr ""
"Liste des chaînes 'app_label.ModelName' auxquelles ce jeton peut accéder."

msgid "Is Active"
msgstr "Est actif"

msgid "Inactive tokens are rejected without being deleted."
msgstr "Les jetons inactifs sont rejetés sans être supprimés."

msgid "Created At"
msgstr "Créé le"

msgid "Last Used At"
msgstr "Dernière utilisation le"

msgid "API Token"
msgstr "Jeton d'API"

msgid "API Tokens"
msgstr "Jetons d'API"

msgid "Can view unmasked PII data"
msgstr "Peut voir les données PII non masquées"

msgid "Exception"
msgstr "Exception"

msgid ""
"Exception class name, or HTTP<code> for a 5xx response without an exception."
msgstr ""
"Nom de la classe d'exception, ou HTTP<code> pour une réponse 5xx sans "
"exception."

msgid "Path"
msgstr "Chemin"

msgid "Method"
msgstr "Méthode"

msgid "Status Code"
msgstr "Code de statut"

msgid "Fingerprint"
msgstr "Empreinte"

msgid "SHA-256 of exception class + path — groups repeats of the same error."
msgstr ""
"SHA-256 de la classe d'exception + chemin — regroupe les répétitions de la "
"même erreur."

msgid "Traceback"
msgstr "Trace"

msgid "Occurred At"
msgstr "Survenu le"

msgid "Error Event"
msgstr "Événement d'erreur"

msgid "Error Events"
msgstr "Événements d'erreur"

msgid "Created"
msgstr "Créé"

msgid "Updated"
msgstr "Mis à jour"

msgid "Deleted"
msgstr "Supprimé"

msgid "Actor"
msgstr "Acteur"

msgid "Actor (snapshot)"
msgstr "Acteur (instantané)"

msgid "IP Address"
msgstr "Adresse IP"

msgid "User Agent"
msgstr "Agent utilisateur"

msgid "Content Type"
msgstr "Type de contenu"

msgid "App Label"
msgstr "Étiquette de l'application"

msgid "Model"
msgstr "Modèle"

msgid "Object ID"
msgstr "ID de l'objet"

msgid "Object"
msgstr "Objet"

msgid "Before/after field diff, if any."
msgstr "Différence de champ avant/après, le cas échéant."

msgid "Timestamp"
msgstr "Horodatage"

msgid "Audit Log"
msgstr "Journal d'audit"

msgid "Audit Logs"
msgstr "Journaux d'audit"

msgid "Audit log entries are immutable and cannot be modified."
msgstr ""
"Les entrées du journal d'audit sont immuables et ne peuvent pas être "
"modifiées."

msgid "Audit log entries are immutable and cannot be deleted."
msgstr ""
"Les entrées du journal d'audit sont immuables et ne peuvent pas être "
"supprimées."

msgid "Pending"
msgstr "En attente"

msgid "Processing"
msgstr "En cours de traitement"

msgid "Completed"
msgstr "Terminé"

msgid "Failed"
msgstr "Échoué"

msgid "Cancelled"
msgstr "Annulé"

msgid "Format"
msgstr "Format"

msgid "Filters"
msgstr "Filtres"

msgid "ORM field=value filters applied to the export queryset."
msgstr "Filtres ORM champ=valeur appliqués au queryset d'exportation."

msgid "Total Rows"
msgstr "Lignes totales"

msgid "Processed Rows"
msgstr "Lignes traitées"

msgid "Rows written so far — drives progress-percent and ETA reporting."
msgstr ""
"Lignes écrites jusqu'à présent — pilote le pourcentage de progression et "
"l'estimation du temps restant."

msgid "Resume Cursor (PK)"
msgstr "Curseur de reprise (PK)"

msgid ""
"Primary key of the last exported row; blank means start from the beginning."
msgstr ""
"Clé primaire de la dernière ligne exportée ; vide signifie recommencer "
"depuis le début."

msgid "Resume Byte Offset"
msgstr "Décalage d'octets de reprise"

msgid "Byte length of the working file confirmed at cursor_pk."
msgstr "Longueur en octets du fichier de travail confirmée à cursor_pk."

msgid "File Name"
msgstr "Nom du fichier"

msgid "Error"
msgstr "Erreur"

msgid "Requested By"
msgstr "Demandé par"

msgid "Started At"
msgstr "Démarré le"

msgid "Finished At"
msgstr "Terminé le"

msgid "Export Job"
msgstr "Tâche d'exportation"

msgid "Export Jobs"
msgstr "Tâches d'exportation"

msgid ""
"Primary key of the last indexed row; blank means start from the beginning."
msgstr "Clé primaire de la dernière ligne indexée ; vide signifie recommencer depuis le début."

msgid "Reindex Job"
msgstr "Tâche de réindexation"

msgid "Reindex Jobs"
msgstr "Tâches de réindexation"

msgid "Skip to main content"
msgstr "Aller au contenu principal"

msgid "SnapAdmin on GitHub (opens in a new tab)"
msgstr "SnapAdmin sur GitHub (s'ouvre dans un nouvel onglet)"

msgid "System entry points"
msgstr "Points d'entrée du système"

msgid "System Entry Points"
msgstr "Points d'entrée du système"

msgid "Managed Models"
msgstr "Modèles gérés"

msgid "Scheduled Cron Jobs"
msgstr "Tâches planifiées"

msgid "Name"
msgstr "Nom"

msgid "Task"
msgstr "Tâche"

msgid "Schedule"
msgstr "Planification"

msgid "Description"
msgstr "Description"

msgid "Data Distribution"
msgstr "Répartition des données"

msgid "Bar chart of record counts per managed model"
msgstr "Diagramme à barres du nombre d'enregistrements par modèle géré"

msgid "System Health"
msgstr "État du système"

msgid "Environment"
msgstr "Environnement"

msgid "Mode"
msgstr "Mode"

msgid "Hostname"
msgstr "Nom d'hôte"

msgid "API Capabilities"
msgstr "Capacités de l'API"

msgid ""
"Automatic CRUD endpoints for all models. Supports filtering, pagination, and "
"token authentication."
msgstr ""
"Points de terminaison CRUD automatiques pour tous les modèles. Prend en "
"charge le filtrage, la pagination et l'authentification par jeton."

msgid "Dynamic schema generation powered by Graphene."
msgstr "Génération dynamique de schéma propulsée par Graphene."

#, python-format
msgid "Built with <strong>SnapAdmin</strong> v%(version)s"
msgstr "Créé avec <strong>SnapAdmin</strong> v%(version)s"

msgid "Language"
msgstr "Langue"

msgid "Single sign-on providers"
msgstr "Fournisseurs d'authentification unique"

msgid "Or sign in with"
msgstr "Ou connectez-vous avec"

msgid "Enter a valid phone number (e.g. +49151234567 or 089-123456)."
msgstr ""
"Saisissez un numéro de téléphone valide (par ex. +49151234567 ou 089-123456)."

msgid "Enter a valid hex color code (e.g. #FF5733 or #F53)."
msgstr ""
"Saisissez un code couleur hexadécimal valide (par ex. #FF5733 ou #F53)."

#, python-format
msgid "File extension '%(ext)s' is not allowed. Allowed: %(allowed)s"
msgstr ""
"L'extension de fichier '%(ext)s' n'est pas autorisée. Autorisées : "
"%(allowed)s"

#, python-format
msgid "File size is %(size)s bytes. Max allowed is %(max_size)s bytes."
msgstr ""
"La taille du fichier est de %(size)s octets. Le maximum autorisé est de "
"%(max_size)s octets."

msgid "Could not verify file encoding."
msgstr "Impossible de vérifier l'encodage du fichier."

#, python-format
msgid "Invalid encoding. Allowed: %(encodings)s"
msgstr "Encodage invalide. Autorisés : %(encodings)s"

